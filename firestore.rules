// ============================================================
// Hermes IdleViber — Firestore Security Rules (Production)
// ============================================================
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- LEADERBOARD ----
    // Anyone can read the leaderboard
    // Only authenticated users can write their own entry
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if request.auth != null 
                    && request.auth.uid == userId;
    }

    // ---- SAVES (cloud saves) ----
    // Only the owning user can read or write their save
    match /saves/{userId} {
      allow read: if request.auth != null 
                   && request.auth.uid == userId;
      allow write: if request.auth != null 
                    && request.auth.uid == userId;
      allow delete: if request.auth != null 
                     && request.auth.uid == userId;
    }

    // ---- DISPLAY NAMES ----
    // Anyone can check if a name is taken (read)
    // Only the claiming user can write
    match /display_names/{docId} {
      allow read: if true;
      allow write: if request.auth != null 
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null 
                     && request.resource.data.uid == request.auth.uid;
    }

    // ---- DENY EVERYTHING ELSE ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
